# Copy this file to .env (or .env.local) for local Netlify dev.
# In production, set these in the Netlify dashboard instead — those values
# take precedence. Items not in the dashboard get loaded from this file.

# --- Supabase (required) ---
# Public, used at build time by the React app.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Server-only. NEVER prefix these with VITE_ and never expose them to the
# browser — the service-role key bypasses Row Level Security.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# --- Stripe (optional; payments + product sync) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Resend (optional; contact-form email) ---
RESEND_API_KEY=
EMAIL_FROM=
ADMIN_EMAIL=

# --- Telegram (optional; admin bot) ---
TELEGRAM_BOT_TOKEN=
TELEGRAM_ADMIN_CHAT=

# --- Zo AI (optional; admin AI helpers) ---
ZO_CLIENT_IDENTITY_TOKEN=
